[Unit]
Description=Dahua Auto Pricing Backend (FastAPI)
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/data/Dahua_Pricing_Auto
Environment=PYTHONUNBUFFERED=1
ExecStart=/data/Dahua_Pricing_Auto/.venv/bin/uvicorn backend.app.main:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
